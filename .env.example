# GEMINI_API_KEY: Optional. Enables the live AI-generated compliance incident reports.
# When unset (or left as the placeholder), the app falls back to a built-in
# rules-based report generator, so every feature still works without a key.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: Optional. Overrides the Gemini model used for incident reports.
# Defaults to "gemini-2.5-flash".
# GEMINI_MODEL="gemini-2.5-flash"

# PORT: Optional. Port the server listens on. Defaults to 3000.
# Cloud Run / AI Studio inject this automatically.
# PORT="3000"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---------------------------------------------------------------------------
# REAL integrations (all optional). See the "Real integrations" section in the
# README. TOTP and passkeys need NO configuration on localhost — they work out
# of the box. OIDC needs an identity provider (a local Keycloak is the easiest).
# ---------------------------------------------------------------------------

# --- WebAuthn / passkeys ---
# rpID must be the host (no scheme/port); origin must exactly match the browser.
# Defaults work for http://localhost:<PORT>. Only set these if you serve the app
# from a different host/origin.
# WEBAUTHN_RP_ID="localhost"
# WEBAUTHN_ORIGIN="http://localhost:3000"

# --- OIDC single sign-on (e.g. local Keycloak) ---
# OIDC_ISSUER="http://localhost:8080/realms/aegisid"
# OIDC_CLIENT_ID="aegisid-app"
# OIDC_CLIENT_SECRET=""            # leave empty for a public (PKCE) client
# OIDC_REDIRECT_URI="http://localhost:3000/api/oidc/callback"  # auto-derived if unset

# --- SAML IdP + bundled sample enterprise app (Globex, sample-sp/) ---
# SAMPLE_SP_URL: where the sample SP runs (used in metadata + the LIVE app card).
# SAMPLE_SP_URL="http://localhost:3400"
# For the SP process itself (npm run sp):
# SP_PORT="3400"
# AEGIS_URL="http://localhost:3000"   # must match the AegisID port

# --- SCIM provisioning (AegisID pushes to the Globex sample app) ---
# Shared bearer token; must match on both processes. Defaults align out of the box.
# SCIM_TOKEN="aegis-scim-demo-token"
